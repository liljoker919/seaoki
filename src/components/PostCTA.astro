---
interface Props {
	title: string;
	description: string;
	buttonLink: string;
	buttonText?: string;
}

const { title, description, buttonLink, buttonText = "View Properties" } = Astro.props;
---

<div class="post-cta">
	<h3 class="post-cta-title">{title}</h3>
	<p class="post-cta-description">{description}</p>
	<a href={buttonLink} class="post-cta-btn">
		{buttonText}
	</a>
</div>

<style>
	.post-cta {
		background-color: #e8f1fb;
		border: 2px solid #0d6efd;
		border-radius: 0.75rem;
		padding: 2rem;
		margin: 2rem 0;
		text-align: center;
	}

	.post-cta-title {
		color: #0d6efd;
		font-weight: 700;
		margin-bottom: 0.75rem;
		font-size: 1.4rem;
	}

	.post-cta-description {
		color: #333;
		margin-bottom: 1.25rem;
		font-size: 1rem;
	}

	.post-cta-btn {
		background-color: #0d6efd;
		color: #fff;
		text-decoration: none;
		font-weight: 700;
		font-size: 1.1rem;
		padding: 0.85rem 2rem;
		border-radius: 0.5rem;
		display: inline-block;
		min-height: 48px;
		transition: background-color 0.2s ease;
	}

	.post-cta-btn:hover {
		background-color: #0b5ed7;
		color: #fff;
	}

	@media (max-width: 576px) {
		.post-cta-btn {
			display: block;
			width: 100%;
			text-align: center;
		}
	}
</style>
